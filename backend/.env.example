# ==============================================================================
# PAVIRA SIGNATURE - BACKEND CONFIGURATION MANIFEST
# ==============================================================================

# Server Connection
PORT=5000
NODE_ENV=development

# Supabase Database Configuration (PostgreSQL)
SUPABASE_URL=https://rpyviraphzesrexovccp.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# JSON Web Token Secret (Min 32 characters recommended)
JWT_SECRET=super_secret_jwt_token_for_pavira_signature_luxury
JWT_EXPIRE=30d

# Taxation Policies
GST_RATE=18

# Nodemailer Email Service Settings
# Option A: Standard predefined service (e.g. Gmail, SendGrid, Outlook)
EMAIL_SERVICE=
# Option B: Manual SMTP parameters (Default: Mailtrap development sandbox)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_SECURE=false
EMAIL_USER=your_smtp_username
EMAIL_PASSWORD=your_smtp_password
EMAIL_FROM="Pavira Signature" <noreply@pavira-signature.com>

# Frontend Endpoint (For CORS policy & Password Reset urls)
FRONTEND_URL=http://localhost:3000

# Stripe Payment Gateway
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Cloudinary Configuration (File uploads for products)
CLOUDINARY_NAME=your_cloudinary_name
